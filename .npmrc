# pnpm: keep isolated linking (the default) so missing dependency declarations
# surface early in a long-lived monorepo.
node-linker=isolated

# tooling that expects to be resolvable from the workspace root
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=*tailwindcss*

# build scripts we trust (pnpm 10 blocks lifecycle scripts by default)
strict-peer-dependencies=false
