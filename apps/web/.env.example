# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>        # server-only, never exposed

# ── Database (Postgres) ───────────────────────────────────────────────────────
# App (request path): pooled connection, as a role that can `set role authenticated`
# so two-tier RLS is enforced (auth.uid() resolves from the request claims).
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres
# Migrations (session pooler / direct).
DIRECT_DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres
# Privileged (jobs / seed) — bypasses RLS.
ADMIN_DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres

# ── Storage ──────────────────────────────────────────────────────────────────
# Create these buckets in Supabase Storage (paths are prefixed orgId/…):
#   logs · media · documents · branding

# ── Email (Resend) — notifications ────────────────────────────────────────────
RESEND_API_KEY=
