# --- Database (Supabase Postgres) ---
# Pooled (transaction mode, port 6543) — restricted app_user role. Request path.
DATABASE_URL="postgresql://app_user:PASSWORD@HOST:6543/postgres?sslmode=require"
# Direct (port 5432) — for drizzle-kit migrations (DDL + advisory locks).
DIRECT_DATABASE_URL="postgresql://postgres:PASSWORD@HOST:5432/postgres?sslmode=require"
# Privileged (bypasses RLS) — for Inngest jobs and seed only. Never request path.
ADMIN_DATABASE_URL="postgresql://postgres:PASSWORD@HOST:6543/postgres?sslmode=require"

# --- Auth.js v5 ---
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"
# WebAuthn relying-party id; pin to apex domain in production.
AUTH_WEBAUTHN_RP_ID="localhost"
AUTH_WEBAUTHN_RP_NAME="DronOps"

# --- Supabase Storage (content-addressed evidence) ---
SUPABASE_URL="https://HOST.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="service-role-key"  # server only — never exposed to client
STORAGE_BUCKET="evidence"
